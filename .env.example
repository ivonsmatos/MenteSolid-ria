# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Medplum (camada FHIR clínica) ---
NEXT_PUBLIC_MEDPLUM_BASE_URL=https://api.medplum.com/
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# --- Groq (acolhimento por IA) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Diretório (Sanity opcional) ---
DIRETORIO_PROVIDER=json
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_VERSION=2024-05-01
# SANITY_TOKEN=

# --- Stripe (opcional — sem isso o /painel/assinatura mostra "não configurado") ---
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
